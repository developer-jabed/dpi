    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"AdminPass123\",\n  \"admin\": {\n    \"email\": \"admin@example.com\",\n    \"roleLabel\": \"Super Admin\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/create-admin",
              "host": ["{{base_url}}"],
              "path": ["users", "create-admin"]
            },
            "description": "Create a new admin user"
          },
          "response": []
        }
      ]
    },
