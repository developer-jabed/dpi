              "raw": "{\n  \"password\": \"CRPass123\",\n  \"cr\": {\n    \"email\": \"cr.student@example.com\",\n    \"groupId\": 1,\n    \"studentData\": {\n      \"name\": \"Ahmed Khan\",\n      \"email\": \"cr.student@example.com\",\n      \"roll\": \"001\",\n      \"registration\": \"REG2024001\",\n      \"mobile\": \"+8801234567890\",\n      \"gender\": \"Male\",\n      \"birthDate\": \"2006-05-15\",\n      \"birthnumber\": \"12345678901\",\n      \"fatherName\": \"Father Khan\",\n      \"motherName\": \"Mother Khan\",\n      \"fatherMobile\": \"+8801987654320\",\n      \"motherMobile\": \"+8801876543210\",\n      \"presentAddress\": \"123 Main Street, Dhaka\",\n      \"permanentAddress\": \"456 Back Street, Dhaka\",\n      \"session\": \"2024\",\n      \"departmentId\": 1\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/create-cr",
              "host": ["{{base_url}}"],
              "path": ["users", "create-cr"]
            },
            "description": "Create a Classroom Representative with Student record in single transaction"
          },
          "response": []
        }
      ]
