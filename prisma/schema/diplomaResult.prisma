model DiplomaResult {
  id        Int      @id @default(autoincrement())
  studentId Int?                                        
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull) 

  roll             String    @unique
  instituteCode    String
  instituteName    String
  semester         String
  regulation       String
  examYear         Int
  publishedDate    DateTime?
  gpa1             Float?
  gpa2             Float?
  gpa3             Float?
  gpa4             Float?
  gpa5             Float?
  gpa6             Float?
  gpa7             Float?
  overallGpa       Float?
  status           String
  failedSubjects   Json?
  referredSubjects Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}