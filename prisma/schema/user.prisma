model user {
  id             String     @id @default(uuid())
  email          String     @unique
  password       String
  role           Role       @default(STUDENT)
  needPassChange Boolean    @default(true)
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLogin      DateTime?

  student         Student?
  teacher         Teacher?
  admin           Admin?
  cr              Cr?                 @relation("CRUserRelation")
  attendanceTaken AttendanceSession[] @relation("AttendanceTaken")

  @@map("user")
}

model Student {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @unique @db.ObjectId
  groupId          String   @db.ObjectId
  departmentId     String   @db.ObjectId
  name             String
  email            String   @unique
  roll             String   @unique
  registration     String   @unique
  mobile           String
  gender           String
  birthDate        DateTime
  birthnumber      String
  nid              String?
  fatherName       String
  motherName       String
  fatherMobile     String
  motherMobile     String
  presentAddress   String
  permanentAddress String
  profilePhoto     String?
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User               @relation(fields: [userId], references: [id])
  group            Group              @relation("GroupStudents", fields: [groupId], references: [id])
  department       Department         @relation(fields: [departmentId], references: [id])

  crOfGroup        Group[]            @relation("CRStudent")

  attendanceRecords AttendanceRecord[]
  results           Result[]
}

model Teacher {
  id               Int            @id @default(autoincrement())
  name             String
  email            String       
  mobile           String
  gender           String
  birthDate        DateTime
  birthnumber      String
  nid              String?        @unique
  presentAddress   String
  isDeleted        Boolean        @default(false)
  permanentAddress String
  profilePhoto     String?
  bio              String?
  expertise        String?
  userId           String         @unique
  user             user           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectGroups    SubjectGroup[]
}

model Admin {
  id        Int       @id @default(autoincrement())
  userId    String    @unique
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleLabel String // Super Admin, Sub Admin
  lastLogin DateTime?
}

model Cr {
  id Int @id @default(autoincrement())

  userId String @unique
  user   user   @relation(fields: [userId], references: [id], name: "CRUserRelation")

  groupId Int
  group   Group @relation(fields: [groupId], references: [id], name: "CRGroupRelation")

  studentId Int @unique
  student   Student @relation(name: "CRStudentRelation", fields: [studentId], references: [id])
}